{
  "name": "ecotrack-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development node ./scripts/dev.mjs",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:debug": "npm run build && cross-env NODE_ENV=development node dist/main.js",
    "lint": "eslint . --cache --cache-strategy content --cache-location ../tmp/eslint/api",
    "typecheck": "tsc --noEmit",
    "test": "node ./scripts/run-vitest.mjs --configLoader runner --run",
    "test:coverage": "node ./scripts/run-vitest.mjs --configLoader runner --coverage",
    "test:watch": "node ./scripts/run-vitest.mjs --configLoader runner"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.3.10",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/mapped-types": "^2.0.4",
    "@nestjs/passport": "^10.0.1",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^10.4.22",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "ecotrack-database": "0.1.0",
    "express": "^4.22.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nestjs-pino": "^4.5.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "tslib": "^2.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@nestjs/testing": "^10.3.10",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.10.1",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-security": "^3.0.1",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.17"
  }
}
