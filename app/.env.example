# Frontend template (copy to app/.env.local)
# Only VITE_* keys are allowed in this file.
# Local dev should target the frontend edge origin so Vite proxies /api and /health.
VITE_API_BASE_URL=http://localhost:5173
VITE_SUPABASE_URL=https://example-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_placeholder
VITE_API_TELEMETRY_ENABLED=false
VITE_BASE=/
VITE_DASHBOARD_REFRESH_INTERVAL_MS=300000
VITE_PLANNING_REFRESH_INTERVAL_MS=300000
VITE_PLANNING_SSE_ENABLED=false
VITE_PLANNING_WEBSOCKET_ENABLED=true
VITE_MANAGER_REPORTS_ENABLED=false
VITE_CITIZEN_CHALLENGES_ENABLED=false
VITE_ADMIN_WORKSPACE_ENABLED=false
VITE_USE_LANDING_PAGE=false
VITE_MAP_TILE_URL_TEMPLATE=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_MAP_TILE_ATTRIBUTION=&copy; OpenStreetMap contributors
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_RELEASE_VERSION=dev-local
