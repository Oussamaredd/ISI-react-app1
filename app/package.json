{
  "name": "ecotrack-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/run-vite.mjs --configLoader runner",
    "dev:landing": "node ./scripts/run-vite.mjs --configLoader runner --mode landing",
    "dev:app": "node ./scripts/run-vite.mjs --configLoader runner --mode app",
    "build": "node ./scripts/run-vite.mjs build --configLoader runner && node ./scripts/run-bundle-size-check.mjs",
    "build:landing": "node ./scripts/run-vite.mjs build --configLoader runner --mode landing",
    "build:app": "node ./scripts/run-vite.mjs build --configLoader runner --mode app && node ./scripts/run-bundle-size-check.mjs",
    "preview": "node ./scripts/run-vite.mjs preview --configLoader runner",
    "test": "node ./scripts/run-vitest.mjs --configLoader runner --run",
    "test:realtime": "node ./scripts/run-vitest.mjs --configLoader runner --run src/tests/usePlanningRealtimeSocket.test.tsx src/tests/usePlanningRealtimeStream.test.tsx src/tests/Dashboard.realtimeTransport.test.tsx",
    "test:e2e": "node ./scripts/run-vitest.mjs --configLoader runner --run src/tests/e2e.key-journeys.test.tsx",
    "test:watch": "node ./scripts/run-vitest.mjs --configLoader runner",
    "test:ui": "node ./scripts/run-vitest.mjs --configLoader runner --ui",
    "test:coverage": "node ./scripts/run-vitest.mjs --configLoader runner --coverage",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0 && npm run lint:theme",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "lint:theme": "node ./scripts/validate-theme-contract.mjs",
    "typecheck": "tsc --noEmit",
    "check:bundle-size": "node ./scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "@sentry/react": "^10.45.0",
    "@tanstack/react-query": "^5.90.17",
    "@tanstack/react-query-persist-client": "^5.90.20",
    "@types/leaflet": "^1.9.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.562.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.0.3",
    "react-router-dom": "^7.12.0",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@eslint/js": "^9.39.4",
    "@sentry/vite-plugin": "^5.1.1",
    "@types/node": "^24.10.9",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "4.0.17",
    "@vitest/ui": "4.0.17",
    "autoprefixer": "^10.4.23",
    "c8": "^9.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.0.17"
  }
}
