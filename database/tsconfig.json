{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "incremental": true,
    "tsBuildInfoFile": "../tmp/tsc/database.tsbuildinfo"
  },
  "include": ["index.ts", "client.ts", "env.ts", "schema/**/*.ts", "seeds/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
