# Deploy staging template (runtime values injected by secret manager)
NODE_ENV=production
API_PORT=3001
API_BASE_URL=https://staging.example.com
OTEL_TRACING_ENABLED=false
OTEL_SERVICE_NAME=ecotrack-api
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com
OTEL_TRACES_SAMPLER_RATIO=0.2
ROUTING_API_BASE_URL=https://router.project-osrm.org
ROUTING_TIMEOUT_MS=10000
ROUTING_FAILURE_THRESHOLD=5
ROUTING_RESET_WINDOW_MS=30000
IOT_INGESTION_ENABLED=true
IOT_QUEUE_CONCURRENCY=50
IOT_QUEUE_BATCH_SIZE=500
IOT_BACKPRESSURE_THRESHOLD=100000
IOT_MAX_BATCH_SIZE=1000
IOT_VALIDATED_CONSUMER_CONCURRENCY=20
IOT_VALIDATED_CONSUMER_BATCH_SIZE=250
IOT_INGESTION_SHARD_COUNT=12
IOT_VALIDATED_CONSUMER_SHARD_COUNT=12
DATABASE_URL=postgres://postgres:postgres@db-host:5432/ticketdb
# Staging should allow only controlled staging frontend origins.
CORS_ORIGINS=https://staging.example.com
# Frontend URL should stay at origin/root (no /auth or legacy app-page suffixes).
APP_URL=https://staging.example.com

SESSION_SECRET=CHANGE_ME_SESSION_SECRET
SESSION_MAX_AGE=86400000
SESSION_SECURE=true
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_EXPIRES_IN=7d
JWT_ACCESS_SECRET=CHANGE_ME_JWT_ACCESS_SECRET
JWT_ACCESS_EXPIRES_IN=15m

GOOGLE_CLIENT_ID=1234567890-placeholder.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=https://staging.example.com/api/auth/google/callback

DATABASE_POOL_MAX=20
DATABASE_POOLER_URL=postgres://postgres:postgres@pgbouncer.staging.internal:6432/ticketdb
CACHE_ENABLED=true
CACHE_PREFIX=ecotrack
CACHE_DEFAULT_TTL_SECONDS=60
CACHE_DASHBOARD_TTL_SECONDS=30
CACHE_PLANNING_TTL_SECONDS=20
CACHE_ANALYTICS_TTL_SECONDS=60
CACHE_CITIZEN_TTL_SECONDS=30
CACHE_MAX_MEMORY_ENTRIES=2000
CACHE_REDIS_URL=redis://staging-redis:6379
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500
BCRYPT_ROUNDS=12
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_LOGSTASH=true
LOGSTASH_HOST=logstash
LOGSTASH_PORT=5001
ENABLE_METRICS=true
METRICS_PORT=9090
RESPONSE_COMPRESSION_ENABLED=true
RESPONSE_COMPRESSION_THRESHOLD_BYTES=1024
RESPONSE_COMPRESSION_LEVEL=6
ENABLE_REGISTRATION=false
ENABLE_EMAIL_VERIFICATION=true
ENABLE_2FA=true
ENABLE_SEED_DATA=false
ENABLE_SWAGGER=false
WEBHOOK_URL=https://hooks.example.com/staging
WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET
ALERTMANAGER_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME
ALERTMANAGER_SLACK_CHANNEL=ecotrack-alerts-staging
ALERTMANAGER_PAGERDUTY_ROUTING_KEY=CHANGE_ME_PAGERDUTY_ROUTING_KEY
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# SonarCloud (CI quality gate; keep in secure secret store for CI)
SONAR_ORGANIZATION=CHANGE_ME_SONAR_ORGANIZATION
SONAR_PROJECT_KEY=CHANGE_ME_SONAR_PROJECT_KEY
SONAR_TOKEN=CHANGE_ME_SONAR_TOKEN

