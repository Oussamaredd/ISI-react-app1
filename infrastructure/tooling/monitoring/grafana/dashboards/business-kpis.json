{
  "id": null,
  "title": "EcoTrack Business KPIs",
  "tags": ["ecotrack", "business", "kpi"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "hideControls": false,
  "links": [],
