# Mobile template (copy to mobile/.env.local)
# Only EXPO_PUBLIC_* keys are allowed in this file.
# Use a simulator/device reachable API origin here. `localhost` works only when the runtime can resolve the host machine directly.
# Helpers:
# - npm run mobile:api-base
# - npm run mobile:env:lan
# - npm run mobile:env:android-emulator
# - npm run mobile:env:ios-simulator
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001
