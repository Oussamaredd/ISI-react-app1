{
  "name": "ecotrack",
  "version": "1.0.0",
  "description": "Multi-client ticket management monorepo",
  "author": "Oussama Radouane",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "npm run build:database:if-needed && concurrently --kill-others-on-fail -n api,app \"npm:dev:api\" \"npm:dev:app:wait-api\"",
    "dev:app": "npm run dev --workspace=ecotrack-app",
    "dev:mobile": "npm run start --workspace=ecotrack-mobile",
    "dev:app:wait-api": "node ./infrastructure/scripts/wait-for-api-ready.mjs --interval-ms 500 --request-timeout-ms 2000 --timeout-ms 30000 --no-fail && npm run dev:app",
    "dev:api": "npm run dev --workspace=ecotrack-api",
    "dev:database": "npm run watch --workspace=ecotrack-database",
    "dev:infra": "npm run infra:up",
    "dev:doctor": "node ./infrastructure/scripts/dev-doctor.mjs",
    "mobile:android": "npm run android --workspace=ecotrack-mobile",
    "mobile:api-base": "node ./infrastructure/scripts/mobile-api-base.mjs",
    "mobile:env:android-emulator": "node ./infrastructure/scripts/mobile-api-base.mjs --write --target android-emulator",
    "mobile:env:ios-simulator": "node ./infrastructure/scripts/mobile-api-base.mjs --write --target ios-simulator",
    "mobile:env:lan": "node ./infrastructure/scripts/mobile-api-base.mjs --write --target lan",
    "mobile:ios": "npm run ios --workspace=ecotrack-mobile",
    "mobile:start:tunnel": "npm run start --workspace=ecotrack-mobile -- --tunnel",
    "mobile:web": "npm run web --workspace=ecotrack-mobile",
    "clean:artifacts": "node ./infrastructure/scripts/clean-artifacts.mjs",
    "prepare": "node ./infrastructure/scripts/install-git-hooks.mjs",
    "hooks:install": "node ./infrastructure/scripts/install-git-hooks.mjs",
    "build": "npm run validate:workspace-toolchain && npm run build:database:if-needed && concurrently --kill-others-on-fail -n app,api \"npm:build:app\" \"npm:build:api\"",
    "build:app": "npm run build --workspace=ecotrack-app",
    "build:api": "npm run build --workspace=ecotrack-api",
    "build:database": "npm run build --workspace=ecotrack-database",
    "build:database:if-needed": "node ./infrastructure/scripts/build-database-if-needed.mjs",
    "deploy:render:build": "npm ci --include=dev && npm run validate:workspace-toolchain && npm run build:database:if-needed && npm run db:migrate --workspace=ecotrack-database && npm run build:api && npm run validate:api-runtime",
    "deploy:render:start": "npm run start --workspace=ecotrack-api",
    "deploy:render:verify-local": "npm run validate:workspace-toolchain && npm run build:database:if-needed && npm run build:api && npm run validate:api-runtime",
    "test": "npm run validate:workspace-toolchain && npm run test:app && npm run test:mobile && npm run test:api",
    "test:app": "npm run test --workspace=ecotrack-app",
    "test:app:fast": "npm run test:fast --workspace=ecotrack-app",
    "test:app:ui": "npm run test:ui --workspace=ecotrack-app",
    "test:mobile": "npm run test --workspace=ecotrack-mobile",
    "test:mobile:fast": "npm run test:fast --workspace=ecotrack-mobile",
    "test:mobile:ui": "npm run test:ui --workspace=ecotrack-mobile",
    "test:api": "npm run build:database:if-needed && npm run test --workspace=ecotrack-api",
    "test:e2e": "npm run test:e2e --workspace=ecotrack-app",
    "test:realtime": "npm run test:realtime --workspace=ecotrack-app",
    "test:coverage": "npm run validate:workspace-toolchain && npm run test:coverage --workspace=ecotrack-app && npm run test:coverage:mobile && npm run test:coverage:api",
    "test:coverage:mobile": "npm run test:coverage --workspace=ecotrack-mobile",
    "test:coverage:api": "npm run build:database:if-needed && npm run test:coverage --workspace=ecotrack-api",
    "lint": "npm run validate:workspace-toolchain && concurrently --kill-others-on-fail -n app,mobile,api \"npm:lint:app\" \"npm:lint:mobile\" \"npm:lint:api\"",
    "lint:app": "npm run lint --workspace=ecotrack-app",
    "lint:mobile": "npm run lint --workspace=ecotrack-mobile",
    "lint:api": "npm run lint --workspace=ecotrack-api",
    "typecheck": "npm run validate:workspace-toolchain && concurrently --kill-others-on-fail -n app,mobile,api,database \"npm:typecheck:app\" \"npm:typecheck:mobile\" \"npm:typecheck:api\" \"npm:typecheck:database\"",
    "typecheck:app": "npm run typecheck --workspace=ecotrack-app",
    "typecheck:mobile": "npm run typecheck --workspace=ecotrack-mobile",
    "typecheck:api": "npm run typecheck --workspace=ecotrack-api",
    "typecheck:database": "npm run typecheck --workspace=ecotrack-database",
    "check:app": "npm run lint:app && npm run typecheck:app && npm run test:app:fast",
    "check:app:full": "npm run lint:app && npm run typecheck:app && npm run test:app",
    "check:mobile": "npm run lint:mobile && npm run typecheck:mobile && npm run test:mobile:fast",
    "check:mobile:full": "npm run lint:mobile && npm run typecheck:mobile && npm run test:mobile",
    "check:api": "npm run lint:api && npm run typecheck:api && npm run test:api",
    "check:database": "npm run build:database && npm run typecheck:database && npm run db:migrate",
    "db:migrate": "npm run db:migrate --workspace=ecotrack-database",
    "db:generate": "npm run db:generate --workspace=ecotrack-database",
    "db:push": "npm run db:push --workspace=ecotrack-database",
    "db:seed": "npm run db:seed --workspace=ecotrack-database",
    "db:migrate:seed": "npm run db:migrate:seed --workspace=ecotrack-database",
    "validate-env": "node ./infrastructure/scripts/validate-env.mjs",
    "validate-env:local": "node ./infrastructure/scripts/validate-env.mjs --workflow local-dev --files .env,app/.env.local,mobile/.env.local",
    "validate-env:local:template": "node ./infrastructure/scripts/validate-env.mjs --workflow local-dev --files .env.example,app/.env.example,mobile/.env.example",
    "validate-env:docker": "node ./infrastructure/scripts/validate-env.mjs --workflow docker-dev --files infrastructure/environments/.env.docker",
    "validate-env:docker:template": "node ./infrastructure/scripts/validate-env.mjs --workflow docker-dev --files infrastructure/environments/.env.docker.example",
    "validate-env:deploy:dev": "node ./infrastructure/scripts/validate-env.mjs --workflow deploy-dev --files infrastructure/environments/.env.development.example",
    "validate-env:deploy:staging": "node ./infrastructure/scripts/validate-env.mjs --workflow deploy-staging --files infrastructure/environments/.env.staging.example",
    "validate-env:deploy:prod": "node ./infrastructure/scripts/validate-env.mjs --workflow deploy-prod --files infrastructure/environments/.env.production.example",
    "validate:affected": "node ./infrastructure/scripts/run-affected-validation.mjs",
    "validate-env:all": "npm run validate-env:local:template && npm run validate-env:docker:template && npm run validate-env:deploy:dev && npm run validate-env:deploy:staging && npm run validate-env:deploy:prod",
    "validate:full": "npm run validate-env:all && npm run validate-doc-sync && npm run lint && npm run typecheck && npm run test",
    "validate:workspace-toolchain": "node ./infrastructure/scripts/validate-workspace-toolchain.mjs",
    "validate:api-runtime": "node ./infrastructure/scripts/validate-api-runtime.mjs",
    "validate-doc-sync": "node ./infrastructure/scripts/validate-doc-sync.mjs",
    "validate-sonar-coverage-alignment": "node ./infrastructure/scripts/validate-sonar-coverage-alignment.mjs",
    "validate-specs": "node ./infrastructure/scripts/validate-spec-contracts.mjs",
    "ci:cdc:summary": "node ./infrastructure/scripts/ci/generate-cdc-summary.mjs",
    "ci:release:manifest": "node ./infrastructure/scripts/ci/generate-release-manifest.mjs",
    "ci:release:quality-scorecard": "node ./infrastructure/scripts/ci/generate-quality-scorecard.mjs",
    "ci:release:deploy-hooks": "node ./infrastructure/scripts/ci/run-deploy-hooks.mjs",
    "ci:release:smoke": "node ./infrastructure/scripts/ci/run-release-smoke.mjs",
    "ci:synthetic": "node ./infrastructure/scripts/ci/run-synthetic-monitor.mjs",
    "ci:quality:k6": "node ./infrastructure/scripts/ci/run-k6-scenarios.mjs --profile smoke",
    "ci:quality:mutation": "node ./infrastructure/scripts/ci/run-mutation-gate.mjs",
    "ci:quality:visual": "node ./infrastructure/scripts/ci/run-visual-gate.mjs",
    "ci:quality:visual:snapshots": "node ./infrastructure/scripts/ci/run-visual-snapshots.mjs",
    "ci:quality:lighthouse": "node ./infrastructure/scripts/ci/run-lighthouse-gate.mjs",
    "quality:mobile-readiness:verify": "node ./infrastructure/scripts/validate-mobile-readiness.mjs",
    "quality:mobile-readiness": "npm run lint --workspace=ecotrack-mobile && npm run typecheck --workspace=ecotrack-mobile && npm run test:coverage --workspace=ecotrack-mobile && npm run quality:mobile-readiness:verify",
    "quality:product-hardening": "npm run validate-env:all && npm run validate-doc-sync && npm run validate-specs && npm run lint && npm run typecheck && npm run validate-sonar-coverage-alignment && npm run test:e2e && npm run test:realtime && npm run test:coverage && npm run quality:mobile-readiness:verify && npm run build --workspace=ecotrack-app && npm run ci:quality:lighthouse",
    "perf:autocannon": "node ./infrastructure/scripts/performance/run-autocannon.mjs",
    "perf:clinic": "node ./infrastructure/scripts/performance/run-clinic.mjs",
    "perf:clinic:doctor": "node ./infrastructure/scripts/performance/run-clinic.mjs --mode doctor -- node api/dist/main.js",
    "perf:clinic:flame": "node ./infrastructure/scripts/performance/run-clinic.mjs --mode flame -- node api/dist/main.js",
    "perf:clinic:bubbleprof": "node ./infrastructure/scripts/performance/run-clinic.mjs --mode bubbleprof -- node api/dist/main.js",
    "perf:clinic:heapprofiler": "node ./infrastructure/scripts/performance/run-clinic.mjs --mode heapprofiler -- node api/dist/main.js",
    "perf:pgbench": "node ./infrastructure/scripts/performance/run-pgbench-baseline.mjs",
    "perf:cloudflare:purge": "node ./infrastructure/scripts/performance/purge-cloudflare-cache.mjs",
    "infra:up": "npm run docker:dev --workspace=ecotrack-infrastructure",
    "infra:down": "npm run docker:down --workspace=ecotrack-infrastructure",
    "infra:health": "npm run health --workspace=ecotrack-infrastructure",
    "smoke-test": "npm run smoke --workspace=ecotrack-infrastructure"
  },
  "workspaces": [
    "app",
    "mobile",
    "api",
    "database",
    "infrastructure"
  ],
  "overrides": {
    "rollup": "4.59.0",
    "tar": "7.5.11",
    "express": {
      "path-to-regexp": "0.1.13"
    },
    "@nestjs/platform-express": {
      "multer": "2.1.1"
    },
    "socket.io": {
      "socket.io-parser": "4.2.6"
    },
    "socket.io-client": {
      "socket.io-parser": "4.2.6"
    }
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "autocannon": "^8.0.0",
    "clinic": "^13.0.0",
    "concurrently": "^8.2.2"
  }
}
